---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
import { getTool, type Tool } from '../data/tools';

export interface Props {
  slug: string;
}

const { slug } = Astro.props;
const tool: Tool | undefined = getTool(slug);

if (!tool) {
  throw new Error(`Tool not found: ${slug}`);
}

const siteUrl = 'https://text.hypergrad.cn';
const toolUrl = `${siteUrl}/${tool.slug}`;

// 相关工具（过滤掉自身与不存在的 slug）
const relatedTools = tool.related
  .map(s => getTool(s))
  .filter((t): t is Tool => Boolean(t) && t.slug !== tool.slug);

// ===== 结构化数据 Schema（用 @graph 合并，单个 ld+json 脚本）====

// 1. SoftwareApplication
const appSchema = {
  '@type': 'SoftwareApplication',
  'name': tool.name,
  'applicationCategory': 'EditorApplication',
  'operatingSystem': 'Web',
  'description': tool.seoDescription,
  'url': toolUrl,
  'offers': { '@type': 'Offer', 'price': '0', 'priceCurrency': 'CNY' },
  'publisher': { '@type': 'Organization', 'name': 'HyperGrad' },
};

// 2. BreadcrumbList
const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  'itemListElement': [
    { '@type': 'ListItem', 'position': 1, 'name': '首页', 'item': siteUrl },
    { '@type': 'ListItem', 'position': 2, 'name': tool.category, 'item': `${siteUrl}/#${tool.category}` },
    { '@type': 'ListItem', 'position': 3, 'name': tool.name, 'item': toolUrl },
  ],
};

// 3. FAQPage（仅当有 FAQ 时生成）
const faqSchema = tool.faq.length > 0
  ? {
      '@type': 'FAQPage',
      'mainEntity': tool.faq.map(f => ({
        '@type': 'Question',
        'name': f.q,
        'acceptedAnswer': { '@type': 'Answer', 'text': f.a },
      })),
    }
  : null;

const graphItems = faqSchema
  ? [appSchema, breadcrumbSchema, faqSchema]
  : [appSchema, breadcrumbSchema];

const allSchema = {
  '@context': 'https://schema.org',
  '@graph': graphItems,
};
import { getSisterSites } from '../data/sisterSites';
const sisters = getSisterSites('text');
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{tool.seoTitle}</title>
  <meta name="description" content={tool.seoDescription} />
  <meta name="keywords" content={tool.keywords.join(', ')} />
  <link rel="canonical" href={toolUrl} />
  <meta property="og:title" content={`${tool.name} — HyperGrad Text`} />
  <meta property="og:description" content={tool.seoDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={toolUrl} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <!-- 搜索引擎验证 -->
  <meta name="baidu-site-verification" content="codeva-vzBYP5qATg" />
  <script type="application/ld+json" set:html={JSON.stringify(allSchema)} />
  <!-- Baidu Tongji（跨子域追踪 hypergrad.cn） -->
  <script is:inline>
var _hmt = _hmt || [];
_hmt.push(['_setCookieDomain', '.hypergrad.cn']);
(function() {
  var hm = document.createElement("script");
  hm.src = "https://hm.baidu.com/hm.js?a778461c432b29b641ee950a9f686a65";
  var s = document.getElementsByTagName("script")[0];
  s.parentNode.insertBefore(hm, s);
})();
  </script>
</head>
<body>
  <!-- DeepSeal 推广条 -->
  <div class="promo-banner" id="promo-banner">
    <span>
      <strong>DeepSeal</strong> — 本地加密笔记应用，你的隐私只有你说了算。
      <a href="https://hypergrad.cn#pricing" target="_blank" rel="noopener">免费下载 →</a>
    </span>
    <span class="promo-close" onclick="document.getElementById('promo-banner').style.display='none'">×</span>
  </div>

  <Header />

  <div class="layout">
    <Sidebar />

    <main class="main">
      <!-- 面包屑导航 -->
      <nav class="breadcrumb" aria-label="面包屑导航">
        <a href="/">首页</a>
        <span class="breadcrumb-sep">/</span>
        <span>{tool.category}</span>
        <span class="breadcrumb-sep">/</span>
        <span class="breadcrumb-current">{tool.name}</span>
      </nav>

      <!-- 工具页头部 -->
      <div class="tool-header">
        <div class="tool-title-wrap">
          <div class="tool-icon-box">{tool.icon}</div>
          <div>
            <h1 class="tool-title">{tool.name}</h1>
            <p class="tool-desc">{tool.desc}</p>
          </div>
        </div>
        <span class={`tag tag-${tool.priority.toLowerCase()}`}>{tool.priority}</span>
      </div>

      <!-- 工具主体（由各页面通过 slot 传入 React 组件） -->
      <div class="tool-react-root">
        <slot />
      </div>

      <!-- SEO 内容区（页面补充富文本：原理、对比、用例） -->
      <div class="seo-content">
        <slot name="seo-content" />
      </div>

      <!-- FAQ 常见问答（自动从 tools.ts 渲染，同步生成 FAQPage Schema） -->
      {tool.faq.length > 0 && (
        <section class="faq-section">
          <h2>{tool.shortName} 常见问答</h2>
          {tool.faq.map(f => (
            <div class="faq-item">
              <div class="faq-q">{f.q}</div>
              <div class="faq-a">{f.a}</div>
            </div>
          ))}
        </section>
      )}

      <!-- 相关工具（自动内链，传递页面权重） -->
      {relatedTools.length > 0 && (
        <section class="related-section">
          <h2>相关工具</h2>
          <div class="related-grid">
            {relatedTools.map(rt => (
              <a href={`/${rt.slug}`} class="tool-card-home">
                <div class="card-icon">{rt.icon}</div>
                <h3>{rt.name}</h3>
                <p>{rt.desc}</p>
                <div class="card-meta">
                  <span>{rt.category}</span>
                  <span>{rt.priority}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
<!-- CROSS-SITES -->
      <section class="cross-sites-section">
        <h2>HyperGrad 生态还有这些站</h2>
        <div class="cross-sites-grid">
          {sisters.map(s => (
            <a href={s.href} class="cross-site-card" target="_blank" rel="noopener">
              <span class="cross-site-icon">{s.icon}</span>
              <span class="cross-site-info">
                <strong>{s.shortName}</strong>
                <span class="cross-site-hot">{s.hot[0].name} · {s.hot[1].name}</span>
              </span>
              <span class="cross-site-arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>
      </section>

      <!-- 隐私徽章 -->
      <div class="privacy-badge privacy-badge--footer">
        100% 本地处理 · 数据不离开浏览器
      </div>

    </main>
  </div>

  <Footer />
</body>
</html>
