---
import { getSisterSites } from '../data/sisterSites';
const sisters = getSisterSites('text');
---
<header class="header">
  <a href="/" class="header-logo">
    <div class="logo-mark">H</div>
    <div>
      HyperGrad
      <div class="logo-sub">Text · 文本工具箱</div>
    </div>
  </a>
  <nav class="header-nav">
    <a href="/">全部工具</a>
{sisters.map(s => (
      <a href={s.href} class="nav-sister" target="_blank" rel="noopener" title={s.slogan}>
        <span class="nav-sister-icon">{s.icon}</span>
        <span class="nav-sister-name">{s.shortName}</span>
      </a>
    ))}
    <a href="https://hypergrad.cn" target="_blank" rel="noopener">DeepSeal 官网</a>
    <a href="https://hypergrad.cn#pricing" target="_blank" rel="noopener" class="header-cta">下载 DeepSeal</a>
  </nav>
</header>
